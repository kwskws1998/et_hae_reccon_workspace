    "predictor_backend": "heuristic",
    "et_hae_checkpoint": "artifacts/et_hae_checkpoints/smoke/best_model.pt",
    "et_hae_vocab": "artifacts/et_hae_checkpoints/smoke/vocab.json"
  }
}
